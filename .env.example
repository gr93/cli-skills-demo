# GitHub CLI Configuration
# For GitHub.com (default): leave GH_HOST empty or comment it out
# For GitHub Enterprise Server: set to your instance hostname
# GH_HOST=github.company.com

# Generate token at: https://github.com/settings/tokens (or your GHE instance)
# Required scopes: repo, read:org, workflow
GH_TOKEN=your_github_token_here

# Jira CLI Configuration
# Your Jira instance URL (no trailing slash)
JIRA_API_URL=https://yourcompany.atlassian.net

# Authentication type: basic or bearer
JIRA_AUTH_TYPE=bearer

# Generate API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_atlassian_api_token_here

# Your Atlassian account email
JIRA_LOGIN=your.email@example.com

# Confluence CLI Configuration
# Your Confluence instance URL (no trailing slash)
CONFLUENCE_URL=https://yourcompany.atlassian.net/wiki

# Your username (usually email)
CONFLUENCE_USERNAME=your.email@example.com

# API token (can use same token as Jira for Atlassian Cloud)
CONFLUENCE_API_TOKEN=your_atlassian_api_token_here

# Optional: Default Confluence space key
CONFLUENCE_DEFAULT_SPACE=YOURSPACE
